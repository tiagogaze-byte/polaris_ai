# POLARIS AI - Variáveis de Ambiente
# Copie para .env.local para desenvolvimento

# ===== BANCO DE DADOS (Vercel Postgres / Neon) =====
# Obtenha em: vercel.com > seu projeto > Storage > Postgres
POSTGRES_URL="postgres://..."
POSTGRES_PRISMA_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."
POSTGRES_USER="..."
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="..."

# ===== AUTENTICAÇÃO =====
# Gere com: openssl rand -base64 64
JWT_SECRET="seu-jwt-secret-muito-secreto-aqui-min-64-chars"
JWT_EXPIRES_IN="7d"

# ===== GEMINI AI =====
# Obtenha em: aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."

# ===== APP =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="POLARIS AI"
NODE_ENV="development"
